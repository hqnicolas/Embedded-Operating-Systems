{
  "version": 1,
  "author": "Cleber Lourenço Izidoro",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-c-v4", "id": "esp", "top": 10, "left": 25, "attrs": {} },

    {
      "type": "wokwi-rgb-led",
      "id": "rgb1",
      "top": -25,
      "left": 180,
      "attrs": { "common": "cathode" }
    },

    {
      "type": "wokwi-resistor",
      "id": "r1",
      "top": 70,
      "left": 170,
      "rotate": 90,
      "attrs": { "value": "1000" }
    },

    {
      "type": "wokwi-pushbutton",
      "id": "btn1",
      "top": 25,
      "left": -85,
      "attrs": { "color": "green", "xray": "1" }
    },

    {
      "type": "wokwi-pushbutton",
      "id": "btn2",
      "top": 95,
      "left": -85,
      "attrs": { "color": "green", "xray": "1" }
    }
  ],

  "connections": [

    [ "esp:TX", "$serialMonitor:RX", "", [] ],
    [ "esp:RX", "$serialMonitor:TX", "", [] ],

    [ "rgb1:COM", "r1:1", "black", [] ],
    [ "r1:2", "esp:GND.1", "black", [] ],

    [ "rgb1:R", "esp:19", "red", [] ],
    [ "rgb1:G", "esp:18", "green", [] ],
    [ "rgb1:B", "esp:5", "blue", [] ],

    [ "btn1:1.r", "esp:32", "green", [] ],
    [ "btn2:1.r", "esp:33", "green", [] ],

    [ "esp:3V3", "btn1:2.l", "red", [] ],
    [ "esp:3V3", "btn2:2.l", "red", [] ]
  ],

  "dependencies": {}
}